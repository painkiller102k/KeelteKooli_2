@model IEnumerable<KeelteKooli.Models.Training>
@{
    ViewBag.Title = "Trainings";
}

<h2>Trainings</h2>
<p>
    <a class="btn btn-primary" href="@Url.Action("CreateTraining", "Admin")">Create New Training</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Course</th>
            <th>Teacher</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Price</th>
            <th>Max Students</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Keelekursus.Nimetus</td>
                <td>@t.Opetaja.Nimi</td>
                <td>@t.AlgusKuupaev.ToShortDateString()</td>
                <td>@t.LoppKuupaev.ToShortDateString()</td>
                <td>@t.Hind</td>
                <td>@t.MaxOsalejaid</td>
                <td>
                    <a class="btn btn-sm btn-warning" href="@Url.Action("EditTraining","Admin", new { id = t.Id })">Edit</a>
                    <a class="btn btn-sm btn-danger" href="@Url.Action("DeleteTraining","Admin", new { id = t.Id })">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
