@model KeelteKooli.Models.Training
@{
    ViewBag.Title = "Edit Training";
}

<h2>Edit Training</h2>

@using (Html.BeginForm("EditTraining", "Admin", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)

    <div class="mb-3">
        @Html.LabelFor(m => m.KeelekursusId, "Course")
        @Html.DropDownListFor(m => m.KeelekursusId, (SelectList)ViewBag.Courses, "-- Select Course --", new { @class = "form-control" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.OpetajaId, "Teacher")
        @Html.DropDownListFor(m => m.OpetajaId, (SelectList)ViewBag.Teachers, "-- Select Teacher --", new { @class = "form-control" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.AlgusKuupaev)
        @Html.TextBoxFor(m => m.AlgusKuupaev, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.LoppKuupaev)
        @Html.TextBoxFor(m => m.LoppKuupaev, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Hind)
        @Html.TextBoxFor(m => m.Hind, new { @class = "form-control" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.MaxOsalejaid)
        @Html.TextBoxFor(m => m.MaxOsalejaid, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" href="@Url.Action("Trainings", "Admin")">Cancel</a>
}