@model IEnumerable<KeelteKooli.Models.Registration>
@{
    ViewBag.Title = "Students";
}

<h2>Студенты тренинга</h2>

<p>
    <a class="btn btn-secondary" href="@Url.Action("Dashboard", "Opetaja")">← Back to Dashboard</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">На этот тренинг пока никто не зарегистрирован.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Email</th>
                <th>Статус</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.User != null ? item.User.Email : "-")</td>
                    <td>@item.Staatus</td>
                </tr>
            }
        </tbody>
    </table>
}