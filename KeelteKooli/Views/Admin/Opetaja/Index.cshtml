@model IEnumerable<KeelteKooli.Models.Teacher>
@{
    ViewBag.Title = "Teachers";
}

<h2>Teachers</h2>
<p>
    <a class="btn btn-primary" href="@Url.Action("CreateTeacher", "Admin")">Create New Teacher</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Qualification</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var teacher in Model)
        {
            <tr>
                <td>@teacher.Nimi</td>
                <td>@teacher.Kvalifikatsioon</td>
                <td>
                    <a class="btn btn-sm btn-warning" href="@Url.Action("EditTeacher", "Admin", new { id = teacher.Id })">Edit</a>
                    <a class="btn btn-sm btn-danger" href="@Url.Action("DeleteTeacher", "Admin", new { id = teacher.Id })">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
