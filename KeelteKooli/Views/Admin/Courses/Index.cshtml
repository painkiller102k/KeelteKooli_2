@model IEnumerable<KeelteKooli.Models.Course>
@{
    ViewBag.Title = "Courses";
}

<h2>Courses</h2>
<p>
    <a class="btn btn-primary" href="@Url.Action("CreateCourse", "Admin")">Create New Course</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Language</th>
            <th>Level</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Nimetus</td>
                <td>@course.Keel</td>
                <td>@course.Tase</td>
                <td>@course.Kirjeldus</td>
                <td>
                    <a class="btn btn-sm btn-warning" href="@Url.Action("EditCourse", "Admin", new { id = course.Id })">Edit</a>
                    <a class="btn btn-sm btn-danger" href="@Url.Action("DeleteCourse", "Admin", new { id = course.Id })">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
